{
    "manifest_version": 3,
    "name": "Erm...Actually!",
    "version": "1.0",
    "permissions": ["activeTab", "scripting"],
    "icons": {
        "16": "./images/favicon.ico",
        "48": "./images/favicon.ico",
        "128": "./images/favicon.ico"
    },
    "action": {
        "default_popup": "popup.html",
        "default_icon": {
            "16": "./images/favicon.ico",
            "48": "./images/favicon.ico",
            "128": "./images/favicon.ico"
        }
    },
    "content_scripts": [
        {
            "matches": ["https://mail.google.com/*"],
            "js": ["content.js"]
        }
    ]
}